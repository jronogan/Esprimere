generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  STUDIO_OWNER
  STUDENT
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentType {
  CLASS_BOOKING
  STUDIO_BOOKING
  PASS_PURCHASE
}

enum BookingMode {
  INSTANT
  REQUEST
}

enum PassType {
  CREDITS
  UNLIMITED
}

enum ClassLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// ─── Auth.js models ───────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String
  emailVerified DateTime?
  firstName     String?
  lastName      String?
  dateOfBirth   DateTime?
  password      String?
  role          Role      @default(STUDENT)
  image         String?

  // null for STUDIO_OWNER (they own a studio, not belong to one)
  studioId      String?
  studio        Studio?   @relation("StudioMembers", fields: [studioId], references: [id])

  ownedStudio   Studio?   @relation("StudioOwner")
  accounts      Account[]
  sessions      Session[]
  classBookings ClassBooking[]
  studioBookings StudioBooking[]
  userPasses    UserPass[]
  payments      Payment[]
  reviews       Review[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([email, studioId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Studio / Tenant ──────────────────────────────────────────────────────────

model Studio {
  id          String  @id @default(cuid())
  ownerId     String  @unique
  owner       User    @relation("StudioOwner", fields: [ownerId], references: [id])
  name        String
  slug        String  @unique
  description String?
  brandColor  String?
  logoUrl     String?
  isLive      Boolean @default(false)

  members       User[]          @relation("StudioMembers")
  rooms         Room[]
  instructors   Instructor[]
  classSlots    ClassSlot[]
  classBookings ClassBooking[]
  studioBookings StudioBooking[]
  passPackages  PassPackage[]
  userPasses    UserPass[]
  payments      Payment[]
  reviews       Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Room {
  id        String  @id @default(cuid())
  studioId  String
  studio    Studio  @relation(fields: [studioId], references: [id], onDelete: Cascade)
  name      String
  areaSqm   Float?
  maxPax    Int
  amenities String[]
  photos    String[]
  isActive  Boolean  @default(true)

  availability   StudioAvailability[]
  classSlots     ClassSlot[]
  studioBookings StudioBooking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Instructor {
  id       String   @id @default(cuid())
  studioId String
  studio   Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)
  name     String
  bio      String?
  styles   String[]
  photoUrl String?
  isActive Boolean  @default(true)

  classSlots        ClassSlot[]
  bookingOverrides  ClassBooking[] @relation("BookingInstructorOverride")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StudioAvailability {
  id          String      @id @default(cuid())
  roomId      String
  room        Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  dayOfWeek   DayOfWeek
  openTime    String
  closeTime   String
  hourlyRate  Decimal     @db.Decimal(10, 2)
  bookingMode BookingMode @default(INSTANT)

  @@unique([roomId, dayOfWeek])
}

// ─── Class system ─────────────────────────────────────────────────────────────

model ClassSlot {
  id           String    @id @default(cuid())
  studioId     String
  studio       Studio    @relation(fields: [studioId], references: [id], onDelete: Cascade)
  roomId       String
  room         Room      @relation(fields: [roomId], references: [id])
  instructorId String
  instructor   Instructor @relation(fields: [instructorId], references: [id])
  title        String
  genre        String
  level        ClassLevel
  dayOfWeek    DayOfWeek
  startTime    String
  endTime      String
  durationMins Int
  maxPax       Int
  creditCost   Int        @default(1)

  bookings ClassBooking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClassBooking {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  studioId    String
  studio      Studio        @relation(fields: [studioId], references: [id])
  classSlotId String
  classSlot   ClassSlot     @relation(fields: [classSlotId], references: [id])
  date                DateTime
  status              BookingStatus @default(PENDING)
  userPassId          String?
  userPass            UserPass?     @relation(fields: [userPassId], references: [id])
  overrideInstructorId String?
  overrideInstructor  Instructor?  @relation("BookingInstructorOverride", fields: [overrideInstructorId], references: [id])

  payment Payment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, classSlotId, date])
}

// ─── Studio (space) booking ───────────────────────────────────────────────────

model StudioBooking {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  studioId    String
  studio      Studio        @relation(fields: [studioId], references: [id])
  roomId      String
  room        Room          @relation(fields: [roomId], references: [id])
  date             DateTime
  startTime        String
  endTime          String
  totalAmount      Decimal       @db.Decimal(10, 2)
  status           BookingStatus @default(PENDING)
  stripeSessionId  String?       @unique

  payment Payment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Pass / Payment ───────────────────────────────────────────────────────────

model PassPackage {
  id          String   @id @default(cuid())
  studioId    String
  studio      Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)
  name        String
  credits     Int?
  price       Decimal  @db.Decimal(10, 2)
  expiryDays  Int?
  type        PassType @default(CREDITS)
  isActive    Boolean  @default(true)

  userPasses UserPass[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserPass {
  id               String      @id @default(cuid())
  userId           String
  user             User        @relation(fields: [userId], references: [id])
  studioId         String
  studio           Studio      @relation(fields: [studioId], references: [id])
  passPackageId    String
  passPackage      PassPackage @relation(fields: [passPackageId], references: [id])
  creditsRemaining Int?
  expiresAt        DateTime?

  classBookings ClassBooking[]
  payment       Payment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id               String      @id @default(cuid())
  userId           String
  user             User        @relation(fields: [userId], references: [id])
  studioId         String
  studio           Studio      @relation(fields: [studioId], references: [id])
  type             PaymentType
  amount           Decimal     @db.Decimal(10, 2)
  currency         String      @default("SGD")
  stripePaymentId  String?     @unique
  stripeSessionId  String?     @unique

  classBookingId   String?        @unique
  classBooking     ClassBooking?  @relation(fields: [classBookingId], references: [id])
  studioBookingId  String?        @unique
  studioBooking    StudioBooking? @relation(fields: [studioBookingId], references: [id])
  userPassId       String?        @unique
  userPass         UserPass?      @relation(fields: [userPassId], references: [id])

  createdAt DateTime @default(now())
}

// ─── Review ───────────────────────────────────────────────────────────────────

model Review {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id])
  studioId String
  studio   Studio @relation(fields: [studioId], references: [id])
  rating   Int
  comment  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, studioId])
}
